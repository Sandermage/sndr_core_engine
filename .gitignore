# macOS AppleDouble (created by scp from macOS)
._*

# Local IDE / agent settings. `.claude/` is the Claude Code per-project
# config directory (agent definitions, permission allowlists, etc.) —
# operator-only context, never part of the release. CLAUDE.md is the
# project-memory file that Claude Code reads at session start — same
# rationale. Both stay out of the public repo by default; if a maintainer
# wants to share a specific agent definition, copy it out and `git add`
# it explicitly.
.claude/
.claude/settings.local.json
CLAUDE.md

# Environment/secrets
.env
.env.*
# ...but the committed, secret-free scaffold IS tracked (copy it to .env).
!.env.example
*.key
*.pem

# ─────────────────────────────────────────────────────────────────────
# `sndr_private/` — single consolidated private maintainer tree.
#
# Everything that should not ship publicly lives under this one root:
#   sndr_private/planning/   — RU planning + audit + roadmap notes
#                              (was docs/_internal/)
#   sndr_private/internal/   — operator-specific compose + scripts
#                              (was internal/)
#   sndr_private/snapshots/  — pre-arm state captures
#                              (was snapshots/)
#   sndr_private/runs/       — bench / probe outputs
#   sndr_private/pyproject-engine.toml  — commercial-tier wheel template
#
# Single rule → easier to review, no scattered _internal / _private /
# private patterns across the tree.
# ─────────────────────────────────────────────────────────────────────
sndr_private/

# Retired internal-docs path. Content migrated to `sndr_private/planning/`
# (see comment above). Legacy laptops may still carry pre-migration
# leftovers under `docs/_internal/`; this rule keeps git blind to them
# so they cannot be accidentally committed and so audit scripts that
# walk git-tracked files do not see them. Phase 4.A (2026-05-22) added
# this explicit entry alongside the `ALLOWLIST_PREFIXES` defensive
# allowlist in `scripts/audit_public_docs.py`.
docs/_internal/

# Backup / temp files (still allowed anywhere)
*.bak
*.backup-*
*.tmp

# Logs / generated result JSON (bench output, probe runs, …)
*.log
*.results.json
*.bench.json

# Genesis package-data JSON is source — keep it tracked even though the
# generic `*.json` rule above existed historically. Audit 2026-05-14
# (CURRENT_PROJECT_RECHECK_CLEANUP_ERRORS_2026-05-14_eaa44975_RU.md P0-2):
# wheel / clean-clone need these artifacts; the generic `*.json` rule was
# silently dropping them.
!sndr/schemas/
!sndr/schemas/*.json
!sndr/manifests/
!sndr/manifests/*.json
!sndr/configs/
!sndr/configs/**/*.json
!evidence/.gitkeep
!benchmarks/cross_rig_reports/**/*.json

# ─────────────────────────────────────────────────────────────────────
# `evidence/patch_proof/` — static-proof JSONs are operator-generated
# per host (carry host name + measured_at timestamp + commit SHA at
# generation time). Operators run `sndr patches prove --all` after
# clone — see `docs/INSTALL.md` and CI workflow. The directory itself
# stays tracked via the `evidence/.gitkeep` exemption above.
# ─────────────────────────────────────────────────────────────────────
evidence/patch_proof/*.json
!evidence/patch_proof/_waivers/
!evidence/patch_proof/_waivers/*.yaml

# vLLM compiled artifacts
*.so
.cache/

