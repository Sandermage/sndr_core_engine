{
  "name": "sndr-gui-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "typecheck": "tsc -b",
    "gen:api": "openapi-typescript ${SNDR_API_BASE:-http://127.0.0.1:8765}/openapi.json -o src/api/schema.gen.ts",
    "check:api": "openapi-typescript ${SNDR_API_BASE:-http://127.0.0.1:8765}/openapi.json -o /tmp/sndr-schema.check.ts && diff -q src/api/schema.gen.ts /tmp/sndr-schema.check.ts",
    "test:e2e": "playwright test",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.14",
    "vitest": "^4.1.8"
  }
}
