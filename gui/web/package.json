{
  "name": "sndr-gui-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "dev:carbon": "vite --mode=carbon --host 127.0.0.1 --port 5174 --open /index.carbon.html",
    "build": "tsc -b && vite build",
    "build:carbon": "tsc -b && vite build --mode=carbon",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "preview:carbon": "vite preview --mode=carbon --host 127.0.0.1 --port 4174",
    "typecheck": "tsc -b",
    "gen:api": "openapi-typescript ${SNDR_API_BASE:-http://127.0.0.1:8765}/openapi.json -o src/api/schema.gen.ts",
    "check:api": "openapi-typescript ${SNDR_API_BASE:-http://127.0.0.1:8765}/openapi.json -o /tmp/sndr-schema.check.ts && diff -q src/api/schema.gen.ts /tmp/sndr-schema.check.ts",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile",
    "test:e2e": "playwright test",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@carbon/grid": "^11.34.0",
    "@carbon/icons-react": "^11.50.0",
    "@carbon/react": "^1.66.0",
    "@carbon/styles": "^1.66.0",
    "@carbon/themes": "^11.43.0",
    "@ibm/plex": "^6.4.0",
    "@lingui/core": "^4.11.4",
    "@lingui/macro": "^4.11.4",
    "@lingui/react": "^4.11.4",
    "@tanstack/react-query": "^5.62.7",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@lingui/cli": "^4.11.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "sass": "^1.83.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.14",
    "vitest": "^4.1.8"
  }
}
