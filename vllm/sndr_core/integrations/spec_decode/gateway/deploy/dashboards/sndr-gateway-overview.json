{
  "_comment": [
    "SNDR spec-decode gateway — Grafana dashboard skeleton.",
    "Import via Grafana UI: Dashboards -> Import -> Upload JSON file.",
    "Prometheus data-source UID needs to be substituted ($DS_PROM).",
    "Six panels, ordered to match deploy/README.md G4/G5 observability sections.",
    "D2c v1 — Panel 5 (acceptance proxy) is a placeholder; populate when",
    "structured upstream exports acceptance as a metric (not log-scrape)."
  ],
  "title": "SNDR gateway — overview",
  "uid": "sndr-gateway-overview",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["sndr", "spec-decode", "gateway"],
  "timezone": "browser",
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "ds",
        "type": "datasource",
        "query": "prometheus",
        "current": {"text": "Prometheus", "value": "${DS_PROM}"}
      },
      {
        "name": "upstream",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${ds}"},
        "query": "label_values(sndr_upstream_health_state, upstream)",
        "includeAll": true,
        "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Traffic split (5m rate, stacked)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${ds}"},
      "targets": [
        {
          "expr": "rate(genesis_routed_default_total[5m])",
          "legendFormat": "default"
        },
        {
          "expr": "rate(genesis_routed_structured_total[5m])",
          "legendFormat": "structured"
        }
      ],
      "fieldConfig": {
        "defaults": {"custom": {"stacking": {"mode": "normal"}}}
      }
    },
    {
      "id": 2,
      "title": "Fallback reasons (5m rate, stacked)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${ds}"},
      "targets": [
        {
          "expr": "sum by (reason) (rate(genesis_fallback_total[5m]))",
          "legendFormat": "{{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"custom": {"stacking": {"mode": "normal"}}}
      }
    },
    {
      "id": 3,
      "title": "Latency p50 / p95 by upstream + stream",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${ds}"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (upstream, stream, le) (rate(sndr_route_latency_seconds_bucket[5m])))",
          "legendFormat": "{{upstream}}/{{stream}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (upstream, stream, le) (rate(sndr_route_latency_seconds_bucket[5m])))",
          "legendFormat": "{{upstream}}/{{stream}} p95"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 4,
      "title": "Upstream health (1=up, 0.5=degraded, 0=down)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${ds}"},
      "targets": [
        {
          "expr": "sndr_upstream_health_state{upstream=~\"$upstream\"}",
          "legendFormat": "{{upstream}}"
        }
      ],
      "fieldConfig": {"defaults": {"min": 0, "max": 1}}
    },
    {
      "id": 5,
      "title": "Structured acceptance proxy (placeholder)",
      "type": "stat",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 6},
      "datasource": {"type": "prometheus", "uid": "${ds}"},
      "targets": [
        {
          "expr": "vector(0)",
          "legendFormat": "n/a (D2c v1 placeholder)"
        }
      ],
      "options": {
        "textMode": "value_and_name",
        "graphMode": "none"
      },
      "description": "Placeholder: real structured acceptance will be exported as a metric in a future patch (avoiding brittle PN248 log scrape)."
    },
    {
      "id": 6,
      "title": "Errors (upstream + streaming)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 6},
      "datasource": {"type": "prometheus", "uid": "${ds}"},
      "targets": [
        {
          "expr": "sum by (upstream) (rate(genesis_upstream_error_total[5m]))",
          "legendFormat": "{{upstream}} upstream"
        },
        {
          "expr": "sum by (upstream, reason) (rate(sndr_streaming_error_total[5m]))",
          "legendFormat": "{{upstream}} stream/{{reason}}"
        }
      ]
    }
  ]
}
